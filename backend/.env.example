PORT=5000
MONGO_URI=mongodb://localhost:27017/memevault
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=30d

# Pinata IPFS (for image upload)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_key
PINATA_JWT=your_pinata_jwt

# Smart Contract Addresses (deploy and update these)
MEMEVAULT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
MEMEVAULT_AUCTION_ADDRESS=0x0000000000000000000000000000000000000000
MEMEVAULT_OFFERS_ADDRESS=0x0000000000000000000000000000000000000000

# RPC URL (e.g. Sepolia testnet or local Anvil)
RPC_URL=http://127.0.0.1:8545

NODE_ENV=development
